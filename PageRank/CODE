import numpy as np

def page_rank(graph,d=0.85,iterations=100):

    n=len(graph)
    ranks=np.ones(n)/n

    for _ in range(iterations):
        new_ranks=np.ones(n)*(1-d)/n

        for i in range(n):
            for j in graph[i]:
                new_ranks[j]+=d*ranks[i]/len(graph[i])

        ranks=new_ranks

    return ranks

graph=[
[1,2],
[0,2],
[0,1],
[1,2]
]

print(page_rank(graph))